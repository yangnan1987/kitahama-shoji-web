---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../constants/site';
import { withBase } from '../utils/paths';
import { getCollection } from 'astro:content';

const heroBgHref = withBase('/images/hero-bg.jpg');
const heroBgCss = `url('${heroBgHref}')`;

const noticeEntries = await getCollection('notices');
const latestNotices = noticeEntries
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const dateFmt = new Intl.DateTimeFormat('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="北浜商事株式会社 | トップ"
  description="大阪・中央区を拠点とする不動産会社の公式サイト。会社情報・事業内容・宅建表示を掲載しています。"
>
  <link slot="head" rel="preload" as="image" href={heroBgHref} fetchpriority="high" />
  <section class="hero hero--home" style={`--heroBgCss:${heroBgCss}`}>
    <div class="container heroInner">
      <div class="heroCopy">
        <p class="kicker">大阪・中央区 / 不動産</p>
        <h1 class="heroTitle">
          誠実に、丁寧に。<br />
          住まいと資産の選択を支える。
        </h1>
        <p class="heroLead">
          北浜商事株式会社は、誠実な説明と丁寧な手続きを大切に、不動産に関する情報を分かりやすくお届けします。
        </p>
        <div class="heroCtas" role="group" aria-label="主要導線">
          <a class="btn" href={withBase('/company')}>会社概要を見る</a>
          <a class="btn btnGhost" href={withBase('/contact')}>アクセス</a>
          <a class="btn btnGhost" href={withBase('/legal')}>宅建業者表示</a>
        </div>
      </div>
      <div class="heroAside">
        <div class="heroCard" aria-label="要点">
          <div class="card">
            <div class="cardTitle">拠点</div>
            <div class="cardBody">
              <div class="muted">{SITE.addressLines[0]}</div>
              <div>{SITE.addressLines[1]}</div>
            </div>
          </div>
          <div class="card">
            <div class="cardTitle">サイト開設</div>
            <div class="cardBody">{SITE.launched}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">大切にしていること</h2>
      <div class="grid2and2">
        <div class="panel featureCard">
          <h3 class="panelTitle">説明の透明性</h3>
          <p class="panelText">重要事項や契約条件は、専門用語に頼りすぎず、ご理解いただけるよう整理してご説明します。</p>
        </div>
        <div class="panel featureCard">
          <h3 class="panelTitle">手続きの見える化</h3>
          <p class="panelText">次に何が起きるか、必要な書類は何かを段取りとして共有し、進行状況が把握しやすいようにします。</p>
        </div>
        <div class="panel featureCard">
          <h3 class="panelTitle">法令の遵守</h3>
          <p class="panelText">宅地建物取引業法など関連法令を踏まえ、表示義務・説明義務を誠実に果たします。</p>
        </div>
        <div class="panel featureCard">
          <h3 class="panelTitle">地域に根ざす姿勢</h3>
          <p class="panelText">大阪・中央エリアの暮らしや商環境を踏まえ、現地の文脈に沿ったご提案を心がけます。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tightTop">
    <div class="container">
      <div class="panel panelWide trustPanel">
        <h2 class="panelTitle">宅地建物取引業者として</h2>
        <p class="panelText trustLead">
          当社は宅地建物取引業の免許を取得した事業者です。免許証番号は <strong class="trustLicense">{SITE.takkenLicenseNo}</strong> です。
        </p>
        <div class="sectionCta trustCta">
          <a class="btn btnGhost" href={withBase('/legal')}>宅建業者表示を見る</a>
          <a class="textLink" href={withBase('/faq')}>よくあるご質問</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle">事業のご案内</h2>
      <div class="grid3">
        <div class="panel featureCard">
          <h3 class="panelTitle">売買・仲介</h3>
          <p class="panelText">条件整理から契約まで、安心して進められるよう丁寧にご案内します。</p>
        </div>
        <div class="panel featureCard">
          <h3 class="panelTitle">賃貸</h3>
          <p class="panelText">入居・運用のご要望を踏まえ、最適な選択肢をご提案します。</p>
        </div>
        <div class="panel featureCard">
          <h3 class="panelTitle">管理・コンサルティング</h3>
          <p class="panelText">運用・管理に関するお悩みを整理し、実行可能な形に落とし込みます。</p>
        </div>
      </div>
      <div class="sectionCta">
        <a class="textLink" href={withBase('/business')}>事業内容の詳細へ</a>
      </div>
    </div>
  </section>

  <section class="section section--tightTop">
    <div class="container">
      <h2 class="sectionTitle">お知らせ</h2>
      <ul class="homeNoticeList">
        {
          latestNotices.map((entry) => (
            <li class="homeNoticeItem">
              <a class="homeNoticeLink" href={withBase(`/notices/${entry.id}`)}>
                <time class="homeNoticeDate" datetime={entry.data.date.toISOString()}>
                  {dateFmt.format(entry.data.date)}
                </time>
                <span class="homeNoticeTitle">{entry.data.title}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <div class="sectionCta">
        <a class="textLink" href={withBase('/notices')}>お知らせ一覧へ</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero--home {
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }

  .hero--home::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: var(--heroBgCss);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero--home::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      rgba(251, 251, 250, 0.94) 0%,
      rgba(251, 251, 250, 0.78) 32%,
      rgba(251, 251, 250, 0.52) 58%,
      rgba(251, 251, 250, 0.22) 100%
    );
  }

  .hero--home .heroInner {
    position: relative;
    z-index: 2;
  }

  .hero--home .card {
    background: rgba(255, 255, 255, 0.88);
    border-color: rgba(22, 24, 29, 0.12);
  }

  @media (max-width: 900px) {
    .hero--home::after {
      background: linear-gradient(
        180deg,
        rgba(251, 251, 250, 0.96) 0%,
        rgba(251, 251, 250, 0.82) 38%,
        rgba(251, 251, 250, 0.58) 68%,
        rgba(251, 251, 250, 0.32) 100%
      );
    }
  }

  .section--tightTop {
    padding-top: 8px;
  }

  .grid2and2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }

  @media (max-width: 900px) {
    .grid2and2 {
      grid-template-columns: 1fr;
    }
  }

  .trustPanel .trustLead {
    margin-bottom: 0;
  }

  .trustLicense {
    color: var(--text);
    font-weight: 700;
  }

  .trustCta {
    margin-top: 14px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px 20px;
    align-items: center;
  }

  .homeNoticeList {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
    border-radius: var(--radius);
    border: 1px solid rgba(22, 24, 29, 0.1);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.74);
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.06);
  }

  .homeNoticeItem {
    margin: 0;
    border-bottom: 1px solid rgba(22, 24, 29, 0.08);
  }

  .homeNoticeItem:last-child {
    border-bottom: 0;
  }

  .homeNoticeLink {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 12px 18px;
    padding: 14px 18px;
    align-items: baseline;
    transition: background 160ms ease;
  }

  @media (max-width: 600px) {
    .homeNoticeLink {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }

  .homeNoticeLink:hover {
    background: rgba(31, 58, 90, 0.05);
  }

  .homeNoticeDate {
    font-size: 13px;
    color: var(--muted);
  }

  .homeNoticeTitle {
    font-size: 15px;
    font-weight: 600;
    color: var(--brand);
    text-decoration: underline;
    text-decoration-color: rgba(31, 58, 90, 0.35);
    text-underline-offset: 3px;
  }
</style>
