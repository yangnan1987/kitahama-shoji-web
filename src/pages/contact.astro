---
import BaseLayout from '../layouts/BaseLayout.astro';
import AddressBlock from '../components/AddressBlock.astro';
import PageDecor from '../components/illustrations/PageDecor.astro';
import { withBase } from '../utils/paths';

/** 事務所周辺の概略（OpenStreetMap 埋め込み用 bbox） */
const mapEmbedSrc =
  'https://www.openstreetmap.org/export/embed.html?bbox=135.4985%2C34.6710%2C135.5045%2C34.6750&layer=mapnik';
const mapLinkHref =
  'https://www.openstreetmap.org/search?query=' +
  encodeURIComponent('大阪市中央区東心斎橋1-3-10');
---

<BaseLayout
  title="北浜商事株式会社 | アクセス"
  description="北浜商事株式会社の所在地のご案内。"
>
  <section class="pageHead">
    <div class="container pageHeadDecor">
      <div>
        <p class="kicker">Access</p>
        <h1 class="pageTitle">アクセス</h1>
        <p class="pageLead">
          事務所の所在地を掲載しています。地図は参考用です。
        </p>
      </div>
      <PageDecor variant="access" />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="twoCol accessGrid">
        <div class="accessCol">
          <div class="panel">
            <h2 class="panelTitle">所在地</h2>
            <AddressBlock hideTitle />
            <p class="panelText muted accessNote">
              ※表記は公開用の整理です。訪問の際はエントランス表示等にご注意ください。
            </p>
          </div>
          <div class="panel">
            <h2 class="panelTitle">公共交通の目安</h2>
            <p class="panelText">
              最寄りは<strong>大阪メトロ御堂筋線・長堀鶴見緑地線「心斎橋」駅</strong>周辺となる場合が多いです。出口や徒歩ルートは駅構内の案内や地図アプリでご確認ください。
            </p>
            <p class="panelText muted accessNote">
              ※実際の所要時間は経路・混雑により異なります。ビル入口・エレベーター表示は現地でご確認ください。
            </p>
          </div>
          <div class="sectionCta">
            <a class="btn btnGhost" href={withBase('/company')}>会社概要へ</a>
            <a class="btn btnGhost" href={withBase('/legal')}>宅建業者表示</a>
          </div>
        </div>
        <div class="accessCol">
          <div class="mapWrap">
            <iframe
              title="事務所周辺の地図（OpenStreetMap）"
              class="mapFrame"
              src={mapEmbedSrc}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            />
          </div>
          <p class="mapCredit muted">
            <a class="textLink" href={mapLinkHref} target="_blank" rel="noopener noreferrer">
              地図を大きく表示（OpenStreetMap）
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .accessGrid {
    align-items: start;
  }

  .accessCol {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .accessNote {
    margin-top: 12px;
    margin-bottom: 0;
  }

  .mapWrap {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid rgba(22, 24, 29, 0.12);
    box-shadow: var(--shadow);
    background: var(--surface);
    aspect-ratio: 4 / 3;
    min-height: 220px;
  }

  .mapFrame {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .mapCredit {
    margin: 0;
    font-size: 13px;
  }

  @media (max-width: 900px) {
    .accessGrid .accessCol:first-child {
      order: 1;
    }
    .accessGrid .accessCol:last-child {
      order: 0;
    }
  }
</style>
