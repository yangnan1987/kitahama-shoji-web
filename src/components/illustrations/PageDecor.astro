---
type Props = {
  variant: 'company' | 'business' | 'legal' | 'access' | 'properties' | 'privacy';
};

const { variant } = Astro.props;
---

<div class={`pageDecor pageDecor--${variant}`} aria-hidden="true">
  {variant === 'company' && (
    <svg viewBox="0 0 120 88" xmlns="http://www.w3.org/2000/svg" class="pageDecorSvg">
      <rect x="6" y="6" width="108" height="76" rx="12" fill="rgba(31,58,90,0.06)" stroke="rgba(31,58,90,0.12)" />
      <path d="M28 70 V38 L44 28 L60 38 V70 M68 70 V32 L88 20 L108 32 V70" fill="none" stroke="rgba(31,58,90,0.4)" stroke-width="2" stroke-linecap="round" />
    </svg>
  )}
  {variant === 'business' && (
    <svg viewBox="0 0 120 88" xmlns="http://www.w3.org/2000/svg" class="pageDecorSvg">
      <circle cx="60" cy="44" r="34" fill="rgba(193,139,58,0.08)" stroke="rgba(193,139,58,0.25)" />
      <path d="M36 52 L52 36 L68 52 L84 36" fill="none" stroke="rgba(31,58,90,0.45)" stroke-width="2.2" stroke-linecap="round" />
    </svg>
  )}
  {variant === 'legal' && (
    <svg viewBox="0 0 120 88" xmlns="http://www.w3.org/2000/svg" class="pageDecorSvg">
      <rect x="22" y="10" width="76" height="68" rx="6" fill="rgba(255,255,255,0.7)" stroke="rgba(31,58,90,0.2)" />
      <path d="M34 28 H86 M34 40 H72 M34 52 H80" stroke="rgba(31,58,90,0.25)" stroke-width="2" stroke-linecap="round" />
      <path d="M48 64 H72" stroke="rgba(193,139,58,0.55)" stroke-width="3" stroke-linecap="round" />
    </svg>
  )}
  {variant === 'access' && (
    <svg viewBox="0 0 120 88" xmlns="http://www.w3.org/2000/svg" class="pageDecorSvg">
      <path
        d="M60 14 L92 40 V74 H28 V40 Z"
        fill="rgba(31,58,90,0.07)"
        stroke="rgba(31,58,90,0.22)"
        stroke-width="2"
        stroke-linejoin="round"
      />
      <rect x="48" y="48" width="24" height="26" rx="2" fill="rgba(255,255,255,0.85)" stroke="rgba(31,58,90,0.2)" />
    </svg>
  )}
  {variant === 'properties' && (
    <svg viewBox="0 0 120 88" xmlns="http://www.w3.org/2000/svg" class="pageDecorSvg">
      <rect x="14" y="22" width="92" height="54" rx="10" fill="rgba(31,58,90,0.06)" stroke="rgba(31,58,90,0.14)" />
      <path d="M38 76 V48 L60 32 L82 48 V76" fill="none" stroke="rgba(31,58,90,0.38)" stroke-width="2" stroke-linejoin="round" />
      <rect x="52" y="54" width="16" height="14" rx="2" fill="rgba(193,139,58,0.2)" />
    </svg>
  )}
  {variant === 'privacy' && (
    <svg viewBox="0 0 120 88" xmlns="http://www.w3.org/2000/svg" class="pageDecorSvg">
      <rect x="28" y="18" width="64" height="54" rx="10" fill="rgba(31,58,90,0.06)" stroke="rgba(31,58,90,0.15)" />
      <circle cx="60" cy="44" r="12" fill="none" stroke="rgba(31,58,90,0.35)" stroke-width="2.2" />
      <path d="M56 44 L59 48 L66 40" fill="none" stroke="rgba(31,58,90,0.45)" stroke-width="2" stroke-linecap="round" />
    </svg>
  )}
</div>

<style>
  .pageDecor {
    flex-shrink: 0;
    width: 120px;
    height: 88px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pageDecorSvg {
    width: 100%;
    height: auto;
    max-height: 88px;
  }
</style>
